# Obsidian-Assistance cloud hygiene
# The GitHub repo is the parent directory, containing backend + frontend subdirectories.

# Local/private Obsidian vault data
.obsidian/
.smart-env/
**/.smart-env/
*.ajson

# Generated outputs / caches
outputs/
work/
temp/
cache/
**/outputs/
**/work/
**/temp/
**/cache/
**/.ci-v4-demo/
**/.ci-v4-spec-demo/
**/.ci-v4-report/
**/reports/generate-course-pack-report.json
*.sqlite
*.db
*.log
*.bak*
*.artifact.json

# Course/source materials and large archive dumps
*.mp3
*.mp4
*.m4a
*.wav
*.flac
*.avi
*.mov
*.mkv
*.pdf
*.ppt
*.pptx
*.doc
*.docx
*.xls
*.xlsx
*.zip
*.rar
*.7z

# OCR/ASR generated text dumps
transcripts/
ocr/
asr/
pdf_pages/
**/transcripts/
**/ocr/
**/asr/
**/pdf_pages/

# Local course evidence sidecar extracts: keep manifests/reports, do not upload
# extracted course text, screenshots/keyframes, or ASR transcripts.
**/docs/course-evidence-sidecars/**/text/
**/docs/course-evidence-sidecars/**/visual/
**/docs/course-evidence-sidecars/**/keyframes/

# Python / Node / editor
__pycache__/
*.pyc
.venv/
venv/
node_modules/
dist/
build/
.DS_Store
Thumbs.db
.idea/
.vscode/

# Local Open Design runtime/cache skills, not project source
**/.od-skills/
